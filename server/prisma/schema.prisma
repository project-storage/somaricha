datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER  @map("user")
  OWNER @map("owner")
}

enum ProductStatus {
  IN_STOCK     @map("in_stock")
  OUT_OF_STOCK @map("out_of_stock")
}

enum OrderStatus {
  PENDING   @map("pending")
  PREPARING @map("preparing")
  SHIPPING  @map("shipping")
  DELIVERED @map("delivered")
  CANCELED  @map("canceled")
}

enum PaymentStatus {
  ONLY_CASE      @map("only case")
  CREDIT_CARD    @map("credit card")
  MOBILE_BANKING @map("mobile banking")
}

model User {
  id             Int             @id @default(autoincrement())
  user_name      String          @db.VarChar(100)
  user_lastname  String          @db.VarChar(100)
  user_imageUrl  String?         @db.VarChar(500)
  user_birth     DateTime?       @db.Date
  user_role      UserRole        @default(USER)
  tel            String?         @db.VarChar(20)
  email          String          @unique @db.VarChar(255)
  created_at     DateTime        @default(now()) @db.Timestamp(6)
  updated_at     DateTime        @updatedAt @db.Timestamp(6)

  auth           Auth?
  addressOptions AddressOption[]
  orders         Order[]

  @@map("users")
}

model Auth {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  username   String    @unique @db.VarChar(100)
  password   String    @db.VarChar(255)
  last_login DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)

  @@map("auths")
}

model Product {
  id             Int           @id @default(autoincrement())
  product_name   String        @db.VarChar(255)
  product_detail String        @db.Text
  product_price  Decimal       @default(0) @db.Decimal(10, 2)
  product_image  String        @db.VarChar(500)
  product_status ProductStatus @default(IN_STOCK)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
  updated_at     DateTime      @updatedAt @db.Timestamp(6)

  order_items    OrderItem[]

  @@map("products")
}

model AddressOption {
  id         Int       @id @default(autoincrement())
  user_id    Int
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ao_name    String    @db.VarChar(255)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)

  addresses  Address[]

  @@map("address_options")
}

model Address {
  id             Int           @id @default(autoincrement())
  ao_id          Int
  addressOption  AddressOption @relation(fields: [ao_id], references: [id], onDelete: Cascade)
  number         String        @db.VarChar(50)
  road           String        @db.VarChar(255)
  subdistrict    String        @db.VarChar(255)
  district       String        @db.VarChar(255)
  province       String        @db.VarChar(255)
  code_zip       Int
  address_detail String?       @db.VarChar(500)
  recipient_name String?       @db.VarChar(255)
  phone          String?       @db.VarChar(20)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
  updated_at     DateTime      @updatedAt @db.Timestamp(6)

  orders         Order[]

  @@map("addresses")
}

model Order {
  id            Int         @id @default(autoincrement())
  user_id       Int
  user          User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PENDING)
  orderdatetime DateTime    @db.Timestamp(6)
  payment_id    Int?        @unique
  payment       Payment?    @relation(fields: [payment_id], references: [id], onDelete: SetNull)
  address_id    Int
  address       Address     @relation(fields: [address_id], references: [id], onDelete: Cascade)
  total_price   Decimal     @db.Decimal(10, 2)
  comemnt_star  Int?
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  updated_at    DateTime    @updatedAt @db.Timestamp(6)

  order_items   OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  order_id    Int
  order       Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_id  Int
  product     Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  total_price Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model Payment {
  id           Int           @id @default(autoincrement())
  payment_name PaymentStatus @default(ONLY_CASE)
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  updated_at   DateTime      @updatedAt @db.Timestamp(6)

  order        Order?

  @@map("payments")
}
