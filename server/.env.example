# ==============================================================================
# SOMARICHA - BACKEND ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Application Port
PORT=3000

# PostgreSQL Database Connection Parameters
# Use 'db' for Docker Compose, or 'localhost' / '127.0.0.1' for local development.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=somaricha

# Database SSL Connection Toggle
DB_SSL=false

# Security & JSON Web Tokens (JWT) Secrets
JWT_SECRET=your_jwt_secret_key_here
