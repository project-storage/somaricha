# ==============================================================================
# SOMARICHA - BACKEND ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Application Port
PORT=3000

# ------------------------------------------------------------------------------
# ENVIRONMENT DATABASE TOGGLE: SUPABASE CLOUD vs. LOCAL DOCKER
# ------------------------------------------------------------------------------

# --- [OPTION A] SUPABASE CLOUD DATABASE ---
# DB_SSL=true
# DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- [OPTION B] LOCAL DOCKER POSTGRESQL ---
# DB_SSL=false
# DATABASE_URL="postgresql://somaricha_user:somaricha_password@localhost:5433/somaricha?schema=public"
# DIRECT_URL="postgresql://somaricha_user:somaricha_password@localhost:5433/somaricha?schema=public"

# ------------------------------------------------------------------------------
# DOCKER / LOCAL BASE PARAMETERS
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=somaricha

# Security & JSON Web Tokens (JWT) Secrets
JWT_SECRET=your_jwt_secret_key_here
