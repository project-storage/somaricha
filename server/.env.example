# ==============================================================================
# SOMARICHA - BACKEND ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================

# Application Port
PORT=3000

# PostgreSQL Database Connection Parameters
# Use 'db' for Docker Compose, or 'localhost' / '127.0.0.1' for local development.
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=somaricha

# Database SSL Connection Toggle (Set to 'true' for Supabase)
DB_SSL=false

# Prisma Database Connection Strings (Prisma 7 standard)
# DATABASE_URL: Pooler connection string (Port 6543 for Supabase PgBouncer)
DATABASE_URL="postgresql://your_database_user:your_database_password@localhost:5433/somaricha?schema=public"

# DIRECT_URL: Direct, non-pooler connection string (Port 5432 for Supabase direct)
# Used by Prisma CLI for running schema migrations.
DIRECT_URL="postgresql://your_database_user:your_database_password@localhost:5433/somaricha?schema=public"

# Security & JSON Web Tokens (JWT) Secrets
JWT_SECRET=your_jwt_secret_key_here
